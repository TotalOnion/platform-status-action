{
  "name": "platform-status-action",
  "version": "1.0.0",
  "description": "GitHub Action that checks an Atlassian Statuspage and reports the current status color to the workflow run and job summary",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "package": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "test": "jest",
    "lint": "eslint src/**/*.ts __tests__/**/*.ts",
    "all": "npm run build && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TotalOnion/platform-status-action.git"
  },
  "keywords": [
    "actions",
    "status",
    "statuspage",
    "monitoring"
  ],
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@vercel/ncc": "^0.38.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.4.5"
  },
  "overrides": {
    "undici": "^7.24.8"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "clearMocks": true,
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  }
}
